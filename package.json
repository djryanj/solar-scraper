{
  "name": "solar-scraper",
  "version": "0.4.2",
  "private": true,
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "start": "node ./bin/www",
    "dev": "nodemon ./bin/www",
    "check": "node --check ./bin/www",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage",
    "test:watch": "node --test --watch",
    "release:bump:patch": "node ./scripts/bump-version.js patch",
    "release:bump:minor": "node ./scripts/bump-version.js minor",
    "release:bump:major": "node ./scripts/bump-version.js major",
    "release:draft": "node ./scripts/create-release-draft.js"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "debug": "^4.4.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "http-errors": "^2.0.1",
    "morgan": "^1.10.1",
    "mqtt": "^5.15.0",
    "prom-client": "^15.1.3",
    "pug": "^3.0.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
